# Railway Environment Variables Template
# Copy these to your Railway project's Variables tab
# DO NOT commit actual values to version control

# ==========================================
# APPLICATION SETTINGS
# ==========================================
APP_NAME="Your E-Commerce Store"
APP_ENV=production
APP_KEY=base64:GENERATE_THIS_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://your-app.railway.app
APP_TIMEZONE=UTC

# ==========================================
# DATABASE SETTINGS
# Railway auto-generates these when you add MySQL
# Use Railway's variable references exactly as shown below.
# Do not use single-brace syntax like ${MYSQLHOST} or typo values.
# ==========================================
DB_CONNECTION=mysql
DB_HOST=${{MYSQLHOST}}
DB_PORT=${{MYSQLPORT}}
DB_DATABASE=${{MYSQLDATABASE}}
DB_USERNAME=${{MYSQLUSER}}
DB_PASSWORD=${{MYSQLPASSWORD}}

# ==========================================
# SESSION & CACHE
# ==========================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=database

# ==========================================
# FILESYSTEM
# ==========================================
FILESYSTEM_DISK=local

# For production, consider cloud storage:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_DEFAULT_REGION=your-region
# AWS_BUCKET=your-bucket
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ==========================================
# MAIL SETTINGS
# Configure your email provider
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=your-smtp-host.com
MAIL_PORT=587
MAIL_USERNAME=your-email@domain.com
MAIL_PASSWORD=your-email-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# Alternative mailers:
# MAIL_MAILER=log (for testing)
# MAIL_MAILER=sendgrid
# MAIL_MAILER=mailgun
# MAIL_MAILER=postmark

# ==========================================
# LOGGING
# ==========================================
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ==========================================
# REDIS (Optional - Railway doesn't provide Redis by default)
# If you add Redis service, uncomment these:
# ==========================================
# REDIS_CLIENT=phpredis
# REDIS_HOST=${{REDIS_HOST}}
# REDIS_PASSWORD=${{REDIS_PASSWORD}}
# REDIS_PORT=${{REDIS_PORT}}

# ==========================================
# BROADCASTING
# ==========================================
BROADCAST_CONNECTION=log

# ==========================================
# MAINTENANCE MODE
# ==========================================
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# ==========================================
# SECURITY
# ==========================================
BCRYPT_ROUNDS=12

# ==========================================
# LOCALIZATION
# ==========================================
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ==========================================
# VITE (If using frontend build tools)
# ==========================================
VITE_APP_NAME="${APP_NAME}"
